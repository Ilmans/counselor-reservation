1783679745a:15:{s:2:"id";i:11;s:4:"slug";s:21:"ilman-sunanuddin-spsi";s:4:"name";s:24:"Ilman Sunanuddin, S.Psi.";s:3:"bio";s:798:"<p>Dengan <strong>7 tahun pengalaman</strong> sebagai konselor pernikahan, saya telah menyaksikan bagaimana komunikasi yang tulus dan pemahaman mendalam dapat mengubah dinamika hubungan secara luar biasa. Pendekatan saya berakar pada nilai-nilai keluarga Indonesia yang kuat, diselaraskan dengan prinsip psikologi modern.</p><p>Saya menggunakan metode <em>holistik</em> yang mempertimbangkan aspek emosional, spiritual, dan kultural dalam setiap proses konseling. Setiap pasangan dan keluarga memiliki cerita uniknya, dan saya berkomitmen untuk hadir sepenuhnya dalam perjalanan pemulihan mereka.</p><p>Selain konseling individual dan pasangan, saya juga menyelenggarakan retreat keluarga bulanan dan program pra-nikah yang telah diikuti oleh lebih dari 200 pasangan di Surabaya dan sekitarnya.</p>";s:10:"photo_path";s:49:"https://ui-avatars.com/api/?name=Ilman+Sunanuddin";s:5:"photo";s:49:"https://ui-avatars.com/api/?name=Ilman+Sunanuddin";s:14:"specialization";a:3:{s:2:"id";i:2;s:4:"name";s:13:"Konselor Umum";s:11:"description";s:51:"Membantu pasangan mengatasi konflik dan komunikasi.";}s:10:"categories";a:3:{i:0;a:4:{s:2:"id";i:3;s:4:"name";s:8:"Hubungan";s:4:"slug";s:8:"hubungan";s:16:"counselors_count";i:0;}i:1;a:4:{s:2:"id";i:4;s:4:"name";s:13:"Trauma & PTSD";s:4:"slug";s:11:"trauma-ptsd";s:16:"counselors_count";i:0;}i:2;a:4:{s:2:"id";i:7;s:4:"name";s:16:"Masalah Keluarga";s:4:"slug";s:16:"masalah-keluarga";s:16:"counselors_count";i:0;}}s:6:"rating";i:0;s:13:"total_reviews";i:0;s:19:"total_consultations";i:0;s:7:"pricing";a:4:{s:4:"type";s:4:"paid";s:7:"is_free";b:0;s:6:"amount";s:9:"155000.00";s:5:"label";s:16:"Rp155.000 / sesi";}s:7:"address";a:4:{s:12:"full_address";s:24:"Jl. Basuki Rahmat No. 89";s:4:"city";s:8:"Surabaya";s:8:"province";s:10:"Jawa Timur";s:8:"maps_url";N;}s:9:"schedules";a:2:{i:0;a:8:{s:2:"id";i:28;s:3:"day";i:2;s:9:"day_l